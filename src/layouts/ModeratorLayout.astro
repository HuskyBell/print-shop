---
import BaseLayout from './BaseLayout.astro';

interface Props {
	title?: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
	<header class="border-b border-slate-200 bg-white">
		<nav class="mx-auto max-w-5xl px-6 py-4 text-sm text-slate-500">
			Moderator nav placeholder
		</nav>
	</header>
	<main class="mx-auto max-w-5xl p-6">
		<!-- slot is the placeholder where child content gets injected -->
		<slot />
	</main>
</BaseLayout>